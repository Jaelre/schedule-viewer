# Next.js Frontend (Public Variables)
NEXT_PUBLIC_DEFAULT_UNIT_NAME="Emergency Department"
NEXT_PUBLIC_SHIFT_CODE_DICT='{"D":{"label":"Day"},"N":{"label":"Night"},"O":{"label":"Off"},"SM":{"label":"Smonto"},"F":{"label":"Ferie"},"M":{"label":"Malattia"},"R":{"label":"Riposo"}}'

# API URL for production (optional, defaults to /api)
# NEXT_PUBLIC_API_URL=https://your-worker.workers.dev

# Optional. When unset, npm run build injects the current git commit SHA.
# NEXT_PUBLIC_SCHEDULE_VIEWER_RELEASE=1.0.0

# Server-side password gate
# ACCESS_PASSWORD=choose-a-strong-password
